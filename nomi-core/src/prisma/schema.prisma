generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ModelPricing {
  id        Int      @id @default(autoincrement())
  model     String   @unique
  input     Float    // USD per 1M input tokens
  output    Float    // USD per 1M output tokens
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("model_pricing")
}